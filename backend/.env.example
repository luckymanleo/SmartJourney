# SmartJourney 环境变量配置
# 复制此文件为 .env 并填写实际值

# ==================== 数据库 ====================
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/smartjourney
REDIS_URL=redis://localhost:6379/0

# ==================== 安全 ====================
SECRET_KEY=change-me-to-a-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_SECONDS=604800

# ==================== 飞猪 FlyAI MCP ====================
FLYAI_API_KEY=
FLYAI_SIGN_SECRET=

# ==================== 高德地图 ====================
GAODE_API_KEY=

# ==================== LLM API（AI 规划推理） ====================
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-pro

# ==================== 短信服务 ====================
# mock: 开发环境使用，验证码固定 9999，不限频率
# aliyun: 阿里云 Dypnsapi 号码认证
SMS_PROVIDER=mock
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=速通互联验证码
SMS_TEMPLATE_CODE=100001
SMS_REGION=cn-shenzhen

# ==================== 服务配置 ====================
APP_NAME=SmartJourney
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# ==================== MCP 超时配置 ====================
MCP_TIMEOUT_SECONDS=15
MCP_MAX_RETRIES=3
MCP_CACHE_TTL_SECONDS=300
