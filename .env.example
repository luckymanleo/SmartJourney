# ============================================================
# SmartJourney（智旅）环境变量
# 复制此文件为 .env 并填入真实值
# .env 不会被提交到 Git
# ============================================================

# ---- 应用 ----
APP_NAME=SmartJourney（智旅）
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ---- 数据库 ----
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/smartjourney
REDIS_URL=redis://host:6379/0
# REDIS_USERNAME=
# REDIS_PASSWORD=

# ---- 安全 ----
SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_SECONDS=604800

# ---- 飞猪 FlyAI MCP ----
# FLYAI_API_KEY=
# FLYAI_SIGN_SECRET=

# ---- 高德地图 ----
GAODE_API_KEY=your-gaode-key

# ---- LLM API ----
LLM_API_KEY=your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ---- 短信 ----
SMS_PROVIDER=mock
# SMS_ACCESS_KEY_ID=
# SMS_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=
SMS_REGION=cn-shenzhen

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost
